# 飞书应用凭证（从 https://open.feishu.cn 获取）
FEISHU_APP_ID=cli_your_app_id_here
FEISHU_APP_SECRET=your_app_secret_here

# Claude Code CLI 路径
# 如果 claude 已在 PATH 中，填 "claude" 即可
# Windows 示例: C:\Users\你\AppData\Roaming\npm\claude.cmd
# macOS/Linux 示例: claude
CLAUDE_CLI=claude

# Claude Code 工作目录
WORK_DIR=.

# 任务超时（秒）
TASK_TIMEOUT=180

# 最大输出长度（超出截断）
MAX_OUTPUT_LENGTH=3500

# Claude 最大对话轮次
MAX_TURNS=30
